# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ambiance?retryWrites=true&w=majority

# --- Serveur ---
PORT=3000

# --- Bridge Phyphox (bridge/phyphox-bridge.js) ---
# URL de l'API "remote access" de Phyphox sur le téléphone (même réseau Wi-Fi).
# Le nom du canal ("amplitude" ci-dessous) dépend de l'expérience Phyphox utilisée.
PHYPHOX_URL=http://192.168.1.42:8080/get?amplitude=full
SERVER_URL=http://localhost:3000
DEVICE_API_KEY=
LOCATION=cafe-exemple
POLL_INTERVAL_MS=5000

# --- Seed (seed/seed.js) ---
SEED_LOCATION=cafe-exemple
